  "dow_3_close" time [not null, default: `'17:00:00'`, note: 'When does this org_unit close on Thursday?']
  "dow_3_note" text
  "dow_4_open" time [not null, default: `'09:00:00'`, note: 'When does this org_unit open on Friday?']
  "dow_4_close" time [not null, default: `'17:00:00'`, note: 'When does this org_unit close on Friday?']
  "dow_4_note" text
