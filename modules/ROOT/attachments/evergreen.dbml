  "ref" boolean
  "holdable" boolean
  "price" numeric(8,2)
  "barcode" text
  "circ_modifier" text
  "circ_as_type" text
  "alert_message" text
  "pub_note" text
  "priv_note" text
  "stat_cat_data" text
  "parts_data" text
  "opac_visible" boolean
  "internal_id" bigint
}

Table "vandelay"."import_item_attr_definition" {
  "id" bigint [pk, increment]
  "owner" integer [not null]
  "name" text [not null]
  "tag" text [not null]
  "keep" boolean [not null, default: `false`]
