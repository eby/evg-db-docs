  "circ_as_type" text
  "alert_message" text
  "opac_visible" text
  "pub_note_title" text
  "pub_note" text
  "priv_note_title" text
  "priv_note" text
  "internal_id" text
  "stat_cat_data" text
  "parts_data" text
}

Table "vandelay"."match_set" {
  "id" integer [pk, increment]
  "name" text [not null]
  "owner" integer [not null]
  "mtype" text [not null, default: `'biblio'`]
}

Table "vandelay"."match_set_point" {
  "id" integer [pk, increment]
  "match_set" integer
  "parent" integer
  "bool_op" text
  "svf" text
  "tag" text
  "subfield" text
  "negate" boolean [default: `false`]
  "quality" integer [not null, default: `1`]
  "heading" boolean [not null, default: `false`]
}

Table "vandelay"."match_set_quality" {
  "id" integer [pk, increment]
  "match_set" integer [not null]
  "svf" text
  "tag" text
  "subfield" text
  "value" text [not null]
  "quality" integer [not null, default: `1`]
}

Table "vandelay"."merge_profile" {
  "id" bigint [pk, increment]
  "owner" integer [not null]
  "name" text [not null]
  "add_spec" text
  "replace_spec" text
  "strip_spec" text
  "preserve_spec" text
  "update_bib_source" boolean [not null, default: `false`]
  "update_bib_editor" boolean [not null, default: `false`]
  "lwm_ratio" numeric
}

Table "vandelay"."queue" {
  "id" bigint [pk, increment]
  "owner" integer [not null]
  "name" text [not null]
  "complete" boolean [not null, default: `false`]
  "match_set" integer
}

Table "vandelay"."queued_authority_record" {
  "id" bigint [pk, increment]
  "create_time" timestamptz [not null, default: `now()`]
  "import_time" timestamptz
  "purpose" text [not null, default: `'import'`]
  "marc" text [not null]
  "quality" integer [not null, default: `0`]
  "queue" integer [not null]
  "imported_as" integer
  "import_error" text
  "error_detail" text
}

Table "vandelay"."queued_authority_record_attr" {
  "id" bigint [pk, increment]
  "record" bigint [not null]
  "field" integer [not null]
  "attr_value" text [not null]
}

Table "vandelay"."queued_bib_record" {
  "id" bigint [pk, increment]
  "create_time" timestamptz [not null, default: `now()`]
  "import_time" timestamptz
  "purpose" text [not null, default: `'import'`]
  "marc" text [not null]
  "quality" integer [not null, default: `0`]
  "queue" integer [not null]
  "bib_source" integer
  "imported_as" bigint
  "import_error" text
  "error_detail" text
}

Table "vandelay"."queued_bib_record_attr" {
  "id" bigint [pk, increment]
  "record" bigint [not null]
  "field" integer [not null]
  "attr_value" text [not null]
}

Table "vandelay"."queued_record" {
  "id" bigint [pk, increment]
  "create_time" timestamptz [not null, default: `now()`]
  "import_time" timestamptz
  "purpose" text [not null, default: `'import'`]
  "marc" text [not null]
  "quality" integer [not null, default: `0`]
}

Table "vandelay"."session_tracker" {
  "id" bigint [pk, increment]
  "session_key" text [not null]
  "name" text [not null]
  "usr" integer [not null]
  "workstation" integer [not null]
  "record_type" text [not null, default: `'bib'`]
  "queue" bigint [not null]
  "create_time" timestamptz [not null, default: `now()`]
  "update_time" timestamptz [not null, default: `now()`]
  "state" text [not null, default: `'active'`]
  "action_type" text [not null, default: `'enqueue'`]
  "total_actions" integer [not null, default: `0`]
  "actions_performed" integer [not null, default: `0`]
}

