// --------------------------------------------------------
// Schema: authority
// Authority Records — MARC authority control and heading management.
// --------------------------------------------------------

TableGroup "authority" {
  "authority"."authority_linking"
  "authority"."bib_linking"
  "authority"."browse_axis"
  "authority"."browse_axis_authority_field_map"
  "authority"."control_set"
  "authority"."control_set_authority_field"
  "authority"."control_set_bib_field"
  "authority"."control_set_bib_field_metabib_field_map"
  "authority"."full_rec"
  "authority"."heading_field"
  "authority"."heading_field_norm_map"
  "authority"."rec_descriptor"
  "authority"."record_entry"
  "authority"."record_note"
  "authority"."simple_heading"
  "authority"."thesaurus"
}

Enum "authority"."heading_purpose" {
  "main"
  "variant"
  "related"
}

Enum "authority"."heading_type" {
  "personal_name"
  "corporate_name"
  "meeting_name"
  "uniform_title"
  "named_event"
  "chronological_term"
  "topical_term"
  "geographic_name"
  "genre_form_term"
  "medium_of_performance_term"
}

Enum "authority"."related_heading_type" {
  "earlier"
  "later"
  "parent organization"
  "broader"
  "narrower"
  "equivalent"
  "other"
}

Enum "authority"."variant_heading_type" {
  "abbreviation"
  "acronym"
  "translation"
  "expansion"
  "other"
  "hidden"
}

Table "authority"."authority_linking" {
  "id" bigint [pk, increment]
  "source" bigint [not null]
  "target" bigint [not null]
  "field" integer [not null]
}

Table "authority"."bib_linking" {
  "id" bigint [pk, increment]
  "bib" bigint [not null]
  "authority" bigint [not null]
}

Table "authority"."browse_axis" {
  "code" text [pk]
  "name" text [not null, unique]
  "sorter" text
  "description" text
}

Table "authority"."browse_axis_authority_field_map" {
  "id" integer [pk, increment]
  "axis" text [not null]
  "field" integer [not null]
}

Table "authority"."control_set" {
  "id" integer [pk, increment]
  "name" text [not null, unique]
  "description" text
}

Table "authority"."control_set_authority_field" {
  "id" integer [pk, increment]
  "main_entry" integer
  "control_set" integer [not null]
  "tag" char(3) [not null]
  "nfi" char(1)
  "sf_list" text [not null]
  "display_sf_list" text [not null]
  "name" text [not null]
  "description" text
  "joiner" text
  "linking_subfield" char(1)
  "heading_field" integer
}

Table "authority"."control_set_bib_field" {
  "id" integer [pk, increment]
  "authority_field" integer [not null]
  "tag" char(3) [not null]
}

Table "authority"."control_set_bib_field_metabib_field_map" {
  "id" integer [pk, increment]
  "bib_field" integer [not null]
  "metabib_field" integer [not null]
}

Table "authority"."full_rec" {
  "id" bigint [pk, increment]
  "record" bigint [not null]
  "tag" char(3) [not null]
  "ind1" text
  "ind2" text
  "subfield" text
  "value" text [not null]
  "index_vector" tsvector [not null]
}

Table "authority"."heading_field" {
  "id" integer [pk, increment]
  "heading_type" authority.heading_type [not null]
  "heading_purpose" authority.heading_purpose [not null]
  "label" text [not null]
  "format" text [not null, default: `'mads21'`]
  "heading_xpath" text [not null]
  "component_xpath" text [not null]
  "type_xpath" text
  "thesaurus_xpath" text
  "thesaurus_override_xpath" text
